autoload -Uz is-at-least

git_current_branch() {
	command git symbolic-ref --quiet --short HEAD 2> /dev/null \
		|| command git describe --contains --all HEAD 2> /dev/null \
		|| command git rev-parse --short HEAD 2> /dev/null
}

git_develop_branch() {
	command git rev-parse --git-dir &> /dev/null || return

	local branch
	for branch in dev devel develop development; do
		if command git show-ref -q --verify refs/heads/$branch; then
			echo $branch
			return 0
		fi
	done

	echo develop
	return 1
}

git_main_branch() {
	command git rev-parse --git-dir &> /dev/null || return

	local branch
	for branch in main trunk mainline default stable master; do
		if command git show-ref -q --verify refs/heads/$branch \
			|| command git show-ref -q --verify refs/remotes/origin/$branch \
			|| command git show-ref -q --verify refs/remotes/upstream/$branch; then
			echo $branch
			return 0
		fi
	done

	echo main
}

